# MailMind Environment Variables
# Copy this file to .env and fill in your values.

# Your primary Gmail address. Required for rules that check if an email is
# directly addressed to you (e.g., the 'directly_addressed' rule).
MAILMIND_USER_EMAIL="your.email@gmail.com"

# --- Optional Overrides ---

# Path to the SQLite database file.
# Defaults to ~/.mailmind/mailmind.db
# MAILMIND_DB_PATH="/path/to/your/mailmind.db"

# Path to the application configuration directory.
# Defaults to ~/.mailmind
# MAILMIND_APP_DIR="/path/to/your/.mailmind"

# How often to poll for new emails, in seconds (in --watch mode).
# Defaults to 120
# MAILMIND_POLL_SECONDS=120

# Maximum number of emails to fetch in a single run.
# Defaults to 50
# MAILMIND_FETCH_MAX=50

# Set to '1' to prevent any actual changes to your Gmail account.
# Actions will be logged, but not executed. Highly recommended for testing.
# Defaults to '0' (off).
# MAILMIND_DRY_RUN=1

# --- Dashboard Configuration ---

# Password to protect the Streamlit dashboard. If unset, no authentication is required.
# DASHBOARD_PASSWORD="your-secure-password"

# Random key used to sign the auth cookie. Falls back to DASHBOARD_PASSWORD if unset.
# Generate with: openssl rand -hex 32
# DASHBOARD_SECRET="your-random-hex-key"

# --- DeepSeek LLM Configuration (Pass 7+) ---

# Your DeepSeek API key. Required to enable the LLM classification stage.
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# DeepSeek model name.
# Defaults to "deepseek-chat"
# DEEPSEEK_MODEL="deepseek-chat"

# DeepSeek API base URL.
# Defaults to "https://api.deepseek.com/v1"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Maximum number of LLM API calls per pipeline run.
# Defaults to 10
# DEEPSEEK_MAX_CALLS_PER_RUN=10

# Skip threshold for LLM calls (0-100).
# Emails with a rules-based score >= this value skip the LLM stage (cost control).
# Defaults to 70
# DEEPSEEK_SKIP_THRESHOLD=70
