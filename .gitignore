cat >> .gitignore << 'EOF'

# Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# SQLite databases (test artifacts)
*.db
*.db-shm
*.db-wal

# Secrets / credentials
credentials.json
*.json.key
.env
token.json

# Aider
.aider*
.ai/

# macOS resource forks (belt-and-suspenders)
**/._.*/
._*

# Python build artifacts
.pytest_cache/
*.egg-info/
EOF