## MailMind example configuration (copy to ~/.mailmind/config.yaml and edit)

database:
  # Path to SQLite DB file; can be relative to user's home (expand when loading)
  path: "~/.mailmind/mailmind.db"

credentials:
  # Where to look for OAuth client credentials (InstalledAppFlow style)
  client_secrets: "~/.mailmind/credentials.json"
  # Token storage (if keyring is not available, a local encrypted file may be used)
  token_file: "~/.mailmind/tokens.json"

privacy:
  # Keep message content on-device by default
  local_only: true
  # If true, allow debug logging of message snippets (NOT recommended)
  safe_debug_mode: false

runtime:
  dry_run: true
  # Minimal Gmail scopes used by the app
  gmail_scopes:
    - "https://www.googleapis.com/auth/gmail.readonly"

paths:
  app_dir: "~/.mailmind"

# Operational toggles
features:
  enable_auto_actions: false

